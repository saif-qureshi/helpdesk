generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  // pgvector not installed yet. Re-enable for Phase 6: extensions = [vector]
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  emailVerified Boolean @default(false) @map("email_verified")
  passwordHash  String? @map("password_hash")
  googleId      String? @unique @map("google_id")
  name          String?
  image         String?

  sessions           Session[]
  members            Member[]
  verificationTokens VerificationToken[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  id        String                @id @default(cuid())
  userId    String                @map("user_id")
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String                @unique
  type      VerificationTokenType
  expiresAt DateTime              @map("expires_at")
  createdAt DateTime              @default(now()) @map("created_at")

  @@index([userId])
  @@map("verification_tokens")
}

enum VerificationTokenType {
  EMAIL_VERIFY
  PASSWORD_RESET
}

/// Tenant root — scoped by its own id, so NOT in TENANT_SCOPED_MODELS.
model Organisation {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?  @map("logo_url")
  industry        String?
  teamSize        String?  @map("team_size")
  defaultLanguage String?  @map("default_language")
  timezone        String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  members     Member[]
  invitations Invitation[]

  @@map("organisations")
}

model Member {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organisationId String   @map("organisation_id")
  role           Role
  email          String
  name           String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([userId, organisationId])
  @@index([organisationId])
  @@map("members")
}

model Invitation {
  id             String           @id @default(cuid())
  organisationId String           @map("organisation_id")
  email          String
  role           Role
  token          String           @unique
  status         InvitationStatus @default(PENDING)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@unique([organisationId, email])
  @@index([organisationId])
  @@map("invitations")
}

enum Role {
  OWNER
  ADMIN
  AGENT
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
}
